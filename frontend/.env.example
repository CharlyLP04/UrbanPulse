# Environment variables example

# Base de datos PostgreSQL
# Local (npm run dev):
DATABASE_URL=postgresql://admin_municipio:password_seguro123@localhost:5432/reportes_db
# Docker (interno):
# DATABASE_URL=postgresql://admin_municipio:password_seguro123@db:5432/reportes_db

# Entorno
NODE_ENV=development
# development: secure=false (cookies via HTTP localhost)
# production: secure=true (cookies solo HTTPS)

# JWT Secrets (CAMBIAR en producción)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Recuperación de contraseña
RESET_TOKEN_EXPIRY_MINUTES=30

# URL base de la app
APP_URL=http://localhost:3000

# Mailer (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password
SMTP_SECURE=false