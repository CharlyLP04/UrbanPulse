# ==============================================================================
# UrbanPulse - Variables de Entorno (Frontend)
# Copia este archivo como .env y llena los valores reales.
# ==============================================================================
# ⚠️  IMPORTANTE PARA DESPLIEGUE:
#     Nunca subas tu archivo .env al repositorio (ya está en .gitignore).
#     Cambia TODOS los valores marcados con [CAMBIAR EN PRODUCCIÓN] antes
#     de desplegar a producción.
# ==============================================================================

# ── Base de Datos ──────────────────────────────────────────────────────────────
# Local (npm run dev, apunta al puerto 5433 del contenedor Docker):
DATABASE_URL="postgresql://admin_municipio:password_seguro123@localhost:5433/reportes_db"
# Dentro de Docker Compose (usa el nombre de servicio "db"):
# DATABASE_URL="postgresql://admin_municipio:password_seguro123@db:5432/reportes_db"
# [CAMBIAR EN PRODUCCIÓN]: Usar la URL de tu base de datos real en el proveedor cloud.

# ── Entorno ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# development → cookies via HTTP (secure: false)
# production  → cookies solo HTTPS (secure: true)
# [CAMBIAR EN PRODUCCIÓN]: NODE_ENV=production

# ── JWT Secrets ────────────────────────────────────────────────────────────────
# [CAMBIAR EN PRODUCCIÓN]: Genera valores aleatorios largos (mínimo 32 chars).
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# ── Recuperación de Contraseña ─────────────────────────────────────────────────
RESET_TOKEN_EXPIRY_MINUTES=30

# ── URL base de la app ─────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
# [CAMBIAR EN PRODUCCIÓN]: APP_URL=https://tu-dominio.com

# ── Mailer SMTP ────────────────────────────────────────────────────────────────
# Configura un proveedor SMTP real. Sin estas variables el envío de correos
# (verificación, recuperación de contraseña, 2FA) fallará con error 500.
#
# Ejemplo con Gmail (requiere App Password, NO tu contraseña normal):
#   1. Activa verificación en 2 pasos en tu cuenta Google.
#   2. Ve a Seguridad -> Contraseñas de aplicaciones -> genera una.
#   3. Usa esa contraseña de 16 chars como SMTP_PASS.
#
# Ejemplo con SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.tu_api_key_real
#
# [CAMBIAR EN PRODUCCIÓN]: Reemplaza con credenciales SMTP reales de tu proveedor.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_16_caracteres
SMTP_SECURE=false
SMTP_FROM="UrbanPulse <no-reply@urbanpulse.com>"

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Necesario para el botón "Continuar con Google".
# Crea credenciales en: https://console.cloud.google.com/
# URI de redirección autorizado: http://localhost:3000/api/auth/google/callback
# [CAMBIAR EN PRODUCCIÓN]: Agrega también tu dominio real como URI autorizado.
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback